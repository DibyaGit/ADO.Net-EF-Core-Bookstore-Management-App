@model List<BookstoreApp.Models.Book>

@{
    ViewData["Title"] = "Bookstore - All Books";
}

<h2>📚 Bookstore Management</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">➕ Add New Book</a>
</p>

@if (Model.Count == 0)
{
    <div class="alert alert-info">No books found. Click "Add New Book" to get started.</div>
}
else
{
    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>Author</th>
                <th>Price</th>
                <th>Year</th>
                <th>Genre</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var book in Model)
            {
                <tr>
                    <td>@book.Title</td>
                    <td>@book.Author</td>
                    <td>@book.Price.ToString("C")</td>
                    <td>@book.PublicationYear</td>
                    <td>@book.Genre</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@book.Id" class="btn btn-sm btn-info">Details</a>
                        <a asp-action="Edit" asp-route-id="@book.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@book.Id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}